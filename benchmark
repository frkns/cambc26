#!/bin/bash
set -e

echo "Benchmarking bot: $1"

# Get our team name and active bot version from cambc status
STATUS=$(cambc status)
OUR_TEAM=$(echo "$STATUS" | grep 'Team:' | sed 's/.*Team: \(.*\) (.*/\1/')
ACTIVE_BOT_FULL=$(echo "$STATUS" | grep 'Active bot:' | sed 's/.*Active bot: \(.*\)/\1/')
ACTIVE_BOT=$(echo "$ACTIVE_BOT_FULL" | sed 's/^v\([0-9]*\).*/\1/')

echo "Our team: $OUR_TEAM"
echo "Active bot: $ACTIVE_BOT_FULL"

# Submit the bot to benchmark
bash submit "$1"

# Get the ladder around us and extract team names (skip header/border lines)
LADDER=$(cambc ladder --around)
echo "$LADDER"
TEAMS=$(echo "$LADDER" | grep '^|' | grep -v '^\-' | grep -v '^| #' | grep -v '^|--' | awk -F'|' '{gsub(/^ +| +$/, "", $3); if ($3 != "") print $3}')

echo "Sending scrimmage requests..."
echo "$TEAMS" | while IFS= read -r TEAM; do
  if [ -z "$TEAM" ] || [ "$TEAM" = "$OUR_TEAM" ]; then
    echo "  Skipping ourselves: $TEAM"
    continue
  fi
  # Look up team ID
  TEAM_ID=$(cambc team search "$TEAM" | grep '│' | head -1 | awk -F'│' '{gsub(/^ +| +$/, "", $2); print $2}')
  if [ -z "$TEAM_ID" ]; then
    # Try ASCII pipe format
    TEAM_ID=$(cambc team search "$TEAM" | grep '^|' | grep -v '^| Team' | grep -v '^|--' | head -1 | awk -F'|' '{gsub(/^ +| +$/, "", $2); print $2}')
  fi
  if [ -z "$TEAM_ID" ]; then
    echo "  Could not find team ID for: $TEAM, skipping"
    continue
  fi
  echo "  Requesting match against: $TEAM ($TEAM_ID)"
  cambc match unrated "$TEAM_ID" || echo "Error requesting matchup"
done

# Activate old bot
echo "Reactivating $ACTIVE_BOT_FULL"
cambc submission activate $ACTIVE_BOT

echo "Done. Benchmark matches requested, reverted to $ACTIVE_BOT_FULL."
