

# ---===
@classmethod
def find_route(cls, start: Position, target: Position,
               ban_target: bool = False) -> tuple[int, Direction | None]:

    sx, sy = start.x, start.y
    _tx, _ty = target.x, target.y

    _w = cls.weight
    _S = cls.STRIDE

    si = ((sx + 3) * 56 + (sy + 3))
    ti = ((_tx + 3) * 56 + (_ty + 3))

    _D = (Direction.NORTH, Direction.NORTHEAST, Direction.EAST, Direction.SOUTHEAST, Direction.SOUTH, Direction.SOUTHWEST, Direction.WEST, Direction.NORTHWEST)

    # ── Same-tile shortcuts ──
    if si == ti:
        if not ban_target:
            return 0, None
        ni = si + -1
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.NORTH):
            return 1, Direction.NORTH
        ni = si + 55
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.NORTHEAST):
            return 1, Direction.NORTHEAST
        ni = si + 56
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.EAST):
            return 1, Direction.EAST
        ni = si + 57
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.SOUTHEAST):
            return 1, Direction.SOUTHEAST
        ni = si + 1
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.SOUTH):
            return 1, Direction.SOUTH
        ni = si + -55
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.SOUTHWEST):
            return 1, Direction.SOUTHWEST
        ni = si + -56
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.WEST):
            return 1, Direction.WEST
        ni = si + -57
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.NORTHWEST):
            return 1, Direction.NORTHWEST
        return 1000000, None

    if ban_target:
        _d = si - ti
        _ad = _d if _d >= 0 else -_d
        if _ad == 1 or _ad == 55 or _ad == 56 or _ad == 57:
            return 0, None

    _save = _w[ti]
    _w[ti] = 1

    try:
        # ── Phase 1: weighted Dijkstra up to 8 ──
        dist = [1000000] * 3136
        fhd  = [0]       * 3136
        dist[si] = 0

        heap  = []
        _hp   = heapq.heappush
        _hpop = heapq.heappop

        _settled = [si]
        _sa = _settled.append

        # Seed: fill-moveable directions only
        ni = si + -1
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.NORTH):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 0
            if ni == ti:
                return w, Direction.NORTH
            _hp(heap, (w, ni))
        ni = si + 55
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.NORTHEAST):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 1
            if ni == ti:
                return w, Direction.NORTHEAST
            _hp(heap, (w, ni))
        ni = si + 56
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.EAST):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 2
            if ni == ti:
                return w, Direction.EAST
            _hp(heap, (w, ni))
        ni = si + 57
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.SOUTHEAST):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 3
            if ni == ti:
                return w, Direction.SOUTHEAST
            _hp(heap, (w, ni))
        ni = si + 1
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.SOUTH):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 4
            if ni == ti:
                return w, Direction.SOUTH
            _hp(heap, (w, ni))
        ni = si + -55
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.SOUTHWEST):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 5
            if ni == ti:
                return w, Direction.SOUTHWEST
            _hp(heap, (w, ni))
        ni = si + -56
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.WEST):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 6
            if ni == ti:
                return w, Direction.WEST
            _hp(heap, (w, ni))
        ni = si + -57
        if _w[ni] < 1000000 and MoveManager.can_fill_move(Direction.NORTHWEST):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = 7
            if ni == ti:
                return w, Direction.NORTHWEST
            _hp(heap, (w, ni))

        # Dijkstra main loop
        phase2_seeds = []
        _p2a = phase2_seeds.append

        while heap:
            d, idx = _hpop(heap)
            if d > dist[idx]:
                continue

            _sa(idx)

            if d >= 8:
                _p2a(idx)
                while heap:
                    _dd, _idx = _hpop(heap)
                    if _dd == dist[_idx]:
                        _sa(_idx)
                        _p2a(_idx)
                break

            _fh = fhd[idx]
            ni = idx + -1
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            ni = idx + 55
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            ni = idx + 56
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            ni = idx + 57
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            ni = idx + 1
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            ni = idx + -55
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            ni = idx + -56
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            ni = idx + -57
            w  = _w[ni]
            if w < 1000000:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))

        if not phase2_seeds:
            return 1000000, None

        # ── Phase 2: bitmask BFS from Dijkstra frontier ──
        Profiler.start()
        _tb = _tx * _S + _ty
        _tm = 1 << _tb
        _uc = cls.passable_int | _tm

        # Remove all settled tiles from unclaimed
        _settled_bits = 0
        for _ci in _settled:
            _cx = _ci // 56 - 3
            _cy = _ci % 56 - 3
            _settled_bits |= 1 << (_cx * _S + _cy)
        _uc &= ~_settled_bits

        # Build per-direction frontier bitmasks + min seed dist
        _fh0 = 0
        _md0 = 1000000
        _fh1 = 0
        _md1 = 1000000
        _fh2 = 0
        _md2 = 1000000
        _fh3 = 0
        _md3 = 1000000
        _fh4 = 0
        _md4 = 1000000
        _fh5 = 0
        _md5 = 1000000
        _fh6 = 0
        _md6 = 1000000
        _fh7 = 0
        _md7 = 1000000

        for _ci in phase2_seeds:
            _cx = _ci // 56 - 3
            _cy = _ci % 56 - 3
            _di = fhd[_ci]
            _bit = 1 << (_cx * _S + _cy)
if _di == 0:
                _fh0 |= _bit
                if dist[_ci] < _md0:
                    _md0 = dist[_ci]
elif _di == 1:
                _fh1 |= _bit
                if dist[_ci] < _md1:
                    _md1 = dist[_ci]
elif _di == 2:
                _fh2 |= _bit
                if dist[_ci] < _md2:
                    _md2 = dist[_ci]
elif _di == 3:
                _fh3 |= _bit
                if dist[_ci] < _md3:
                    _md3 = dist[_ci]
elif _di == 4:
                _fh4 |= _bit
                if dist[_ci] < _md4:
                    _md4 = dist[_ci]
elif _di == 5:
                _fh5 |= _bit
                if dist[_ci] < _md5:
                    _md5 = dist[_ci]
elif _di == 6:
                _fh6 |= _bit
                if dist[_ci] < _md6:
                    _md6 = dist[_ci]
elif _di == 7:
                _fh7 |= _bit
                if dist[_ci] < _md7:
                    _md7 = dist[_ci]

        # Bitmask BFS
        _bfs_d = 0
        while True:
            _any = False

            _f = _fh0
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh0 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md0 + _bfs_d + 1, _D[0]
                else:
                    _fh0 = 0
            _f = _fh1
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh1 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md1 + _bfs_d + 1, _D[1]
                else:
                    _fh1 = 0
            _f = _fh2
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh2 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md2 + _bfs_d + 1, _D[2]
                else:
                    _fh2 = 0
            _f = _fh3
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh3 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md3 + _bfs_d + 1, _D[3]
                else:
                    _fh3 = 0
            _f = _fh4
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh4 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md4 + _bfs_d + 1, _D[4]
                else:
                    _fh4 = 0
            _f = _fh5
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh5 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md5 + _bfs_d + 1, _D[5]
                else:
                    _fh5 = 0
            _f = _fh6
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh6 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md6 + _bfs_d + 1, _D[6]
                else:
                    _fh6 = 0
            _f = _fh7
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh7 = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md7 + _bfs_d + 1, _D[7]
                else:
                    _fh7 = 0

            if not _any:
                break
            _bfs_d += 1

        return 1000000, None

    finally:
        Profiler.end("""BfsBureau.find_route[bfs]""")
        _w[ti] = _save

# ===---
