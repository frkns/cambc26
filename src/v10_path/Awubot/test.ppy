{% import 'debug/debug.j2' as D %}
{% import 'debug/profiler.j2' as P %}


# ---===
@classmethod
def find_route(cls, start: Position, target: Position,
               ban_target: bool = False) -> tuple[int, Direction | None]:
    {% set WEIGHTED_DEPTH = 8 %}

    sx, sy = start.x, start.y
    _tx, _ty = target.x, target.y

    _w = cls.weight
    _S = cls.STRIDE

    si = {{ encode_pos('sx', 'sy') }}
    ti = {{ encode_pos('_tx', '_ty') }}

    _D = ({% for d in range(8) %}{{ directions[d] }}{% if not loop.last %}, {% endif %}{% endfor %})

    # ── Same-tile shortcuts ──
    if si == ti:
        if not ban_target:
            return 0, None
        {% for dir in range(8) %}
        ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
        if _w[ni] < {{ INF }} and MoveManager.can_fill_move({{ directions[dir] }}):
            return 1, {{ directions[dir] }}
        {% endfor %}
        return {{ INF }}, None

    if ban_target:
        _d = si - ti
        _ad = _d if _d >= 0 else -_d
        if _ad == 1 or _ad == {{ PH - 1 }} or _ad == {{ PH }} or _ad == {{ PH + 1 }}:
            return 0, None

    _save = _w[ti]
    _w[ti] = 1

    try:
        # ── Phase 1: weighted Dijkstra up to {{ WEIGHTED_DEPTH }} ──
        dist = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
        fhd  = [0]       * {{ PADDED_GRID_SIZE }}
        dist[si] = 0

        heap  = []
        _hp   = heapq.heappush
        _hpop = heapq.heappop

        _settled = [si]
        _sa = _settled.append

        # Seed: fill-moveable directions only
        {% for dir in range(8) %}
        ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
        if _w[ni] < {{ INF }} and MoveManager.can_fill_move({{ directions[dir] }}):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = {{ dir }}
            if ni == ti:
                return w, {{ directions[dir] }}
            _hp(heap, (w, ni))
        {% endfor %}

        # Dijkstra main loop
        phase2_seeds = []
        _p2a = phase2_seeds.append

        while heap:
            d, idx = _hpop(heap)
            if d > dist[idx]:
                continue

            _sa(idx)

            if d >= {{ WEIGHTED_DEPTH }}:
                _p2a(idx)
                while heap:
                    _dd, _idx = _hpop(heap)
                    if _dd == dist[_idx]:
                        _sa(_idx)
                        _p2a(_idx)
                break

            _fh = fhd[idx]
            {% for dir in range(8) %}
            ni = idx + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            w  = _w[ni]
            if w < {{ INF }}:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            {% endfor %}

        if not phase2_seeds:
            return {{ INF }}, None

        # ── Phase 2: bitmask BFS from Dijkstra frontier ──
        {{ P.start() }}
        _tb = _tx * _S + _ty
        _tm = 1 << _tb
        _uc = cls.passable_int | _tm

        # Remove all settled tiles from unclaimed
        _settled_bits = 0
        for _ci in _settled:
            _cx = _ci // {{ PH }} - {{ PAD }}
            _cy = _ci % {{ PH }} - {{ PAD }}
            _settled_bits |= 1 << (_cx * _S + _cy)
        _uc &= ~_settled_bits

        # Build per-direction frontier bitmasks + min seed dist
        {% for dir in range(8) %}
        _fh{{ dir }} = 0
        _md{{ dir }} = {{ INF }}
        {% endfor %}

        for _ci in phase2_seeds:
            _cx = _ci // {{ PH }} - {{ PAD }}
            _cy = _ci % {{ PH }} - {{ PAD }}
            _di = fhd[_ci]
            _bit = 1 << (_cx * _S + _cy)
            {% for dir in range(8) %}
            {% if loop.first %}if{% else %}elif{% endif %} _di == {{ dir }}:
                _fh{{ dir }} |= _bit
                if dist[_ci] < _md{{ dir }}:
                    _md{{ dir }} = dist[_ci]
            {% endfor %}

        # Bitmask BFS
        _bfs_d = 0
        while True:
            _any = False

            {% for dir in range(8) %}
            _f = _fh{{ dir }}
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh{{ dir }} = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        return _md{{ dir }} + _bfs_d + 1, _D[{{ dir }}]
                else:
                    _fh{{ dir }} = 0
            {% endfor %}

            if not _any:
                break
            _bfs_d += 1

        return {{ INF }}, None

    finally:
        {{ P.end('BfsBureau.find_route[bfs]') }}
        _w[ti] = _save

# ===---

