{% import 'debug/debug.j2' as D %}
{% import 'debug/profiler.j2' as P %}


class Unit:
    core_pos: Position
    core_pos_list: list[tuple[int, int]]
    core_pos_set: set[int]

    @staticmethod
    def self_init():
        core_id = Globals.ct.get_tile_building_id(Globals.my_pos)
        Unit.core_pos = Globals.ct.get_position(core_id)
        x = Unit.core_pos.x
        y = Unit.core_pos.y
        Unit.core_pos_list = [
            {% for i in range(9) %}
            (x {{ sign0(Dir.dx[i]) }}, y {{ sign0(Dir.dy[i]) }}),
            {% endfor %}
        ]
        idx = {{ encode_pos('x', 'y') }}
        Unit.core_pos_set = {
            {% for dir in directions %}
            {% set dx, dy = dir.delta() %}
            idx {{ sign0(dx * PH + dy) }},
            {% endfor %}
        }


    @classmethod
    def init(cls):
        Unit.self_init()
        BfsBureau.init()
        Symmetry.predict_enemy_core()


    @classmethod
    def start_turn(cls):
        Globals.start_tick()
        MarketMaker.refresh()

        {{ P.start() }}
        Map.fill_tile_info()
        {{ P.end('fill_tile_info') }}

        {{ P.start() }}
        BfsBureau.update()
        {{ P.end('BfsBureau.update') }}


    @classmethod
    def run_turn(cls):
        pass

    @classmethod
    def end_turn(cls):
        {% set REPORT_ROUND = min(ROUND_LIMIT + 1, 1999) if LOCAL else 1999 %}

        if Globals.round == {{ REPORT_ROUND }}:
            Profiler.report()
        print(f'scale ratio {MarketMaker.scale_ratio:.2f}')

        {# /* if Globals.round == 330: */ #}
            {# /* Globals.ct.resign() */ #}
