    @classmethod
    def debug_now_passable_int_impassable(cls):
        stride = cls.STRIDE
        bits = cls.now_passable_int & cls.board_mask

        for x in range(Map.W):
            for y in range(Map.H):
                bit = 1 << (x * stride + y)
                if not (bits & bit):
                    Debug.dot(Position(x, y), Color.PINK)
