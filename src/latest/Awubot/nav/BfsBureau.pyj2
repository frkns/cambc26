{% set _dlut = [7, 6, 5, 0, -1, 4, 1, 2, 3] %}

class BfsBureau:
    weight: list[int]
    now_weight: list[int]  # copied from weight every turn

    # bitmask
    board_mask: int
    passable_int: int
    now_passable_int: int
    enemy_launcher: int = 0
    ally_launcher: int = 0
    enemy_now_passable_int: int = 0
    STRIDE: int

    passable_bridge: list[bool] = [{{ False }}] * {{ PADDED_GRID_SIZE }}
    harvester_feeder: list[bool] = [False] * {{ PADDED_GRID_SIZE }}
    ally_routing: list[bool] = [False] * {{ PADDED_GRID_SIZE }}  # any ally CONVEYOR/ARMOURED_CONVEYOR/BRIDGE


    weight: list[int] = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
    ti_ore_adj: list[bool] = [False] * {{ PADDED_GRID_SIZE }}

    @classmethod
    def init(cls):
        W, H = Map.W, Map.H

        passable_bridge = cls.passable_bridge
        weight = cls.weight

        row_true = [{{ True }}] * H
        row_1 = [{{ 1 }}] * H
        for x in range(W):
            base = (x + {{ PAD }}) * {{ PH }} + {{ PAD }}
            passable_bridge[base:base + H] = row_true
            weight[base:base + H] = row_1

        S = H + 1
        cls.STRIDE = S
        col_mask = (1 << H) - 1
        p = 0
        for x in range(W):
            p |= col_mask << (x * S)
        cls.passable_int = p
        cls.board_mask = p


# ---===
    @classmethod
    def update(cls):
        tile_info = Map.tile_info
        weight = cls.weight
        stride = cls.STRIDE
        passable_bridge = cls.passable_bridge
        ct = Globals.ct

        for pos, x, y, idx, ti in Map.proc_nearby_tiles:
            bit = 1 << (x * stride + y)

            if ti.env != Environment.WALL:
                if ti.easily_passable:
                    w = 1
                    cls.passable_int |= bit
                elif ti.has_building:
                    w = {{ INF }}
                    cls.passable_int &= ~bit
                else:
                    w = 2
                    cls.passable_int |= bit
            else:
                w = {{ INF }}
                cls.passable_int &= ~bit

            weight[idx] = max(weight[idx], w)

            if (
                ti.env == Environment.EMPTY and
                (
                    (not ti.has_building) or
                    ((etype := ti.entity_type) == EntityType.MARKER) or
                    (ti.is_building_ally and (
                        etype == EntityType.ROAD or etype == EntityType.CORE))
                )
            ):
                passable_bridge[idx] = True
            else:
                passable_bridge[idx] = False
            is_hf = False
            is_ar = False
            if ti.has_building and ti.is_building_ally and ti.entity_type in (EntityType.CONVEYOR, EntityType.ARMOURED_CONVEYOR, EntityType.BRIDGE):
                is_ar = True
                if ti.entity_type in (EntityType.CONVEYOR, EntityType.ARMOURED_CONVEYOR):
                    targ = ti.target
                    if targ is not None:
                        tti = Map.tile_info[targ.x][targ.y]
                        if tti is not None and tti.has_building and tti.entity_type == EntityType.HARVESTER:
                            is_hf = True
            cls.harvester_feeder[idx] = is_hf
            cls.ally_routing[idx] = is_ar

        cls.now_weight = weight.copy()
        now_weight = cls.now_weight
        cls.now_passable_int = cls.passable_int

        # remove enemy launchers from our passable mask (we avoid their zones)
        wide = (cls.enemy_launcher | (cls.enemy_launcher << 1) | (cls.enemy_launcher >> 1)) & cls.board_mask
        expanded = (wide | (wide >> stride) | (wide << stride)) & cls.board_mask
        cls.now_passable_int &= ~expanded

        # [NEW] build enemy_now_passable_int: same base passable_int, but carve
        # out 3x3 zones around ALLY launchers (which block ENEMY bot movement).
        # Enemy bots are free to walk under their own launchers (= our enemy_launcher),
        # so we do NOT subtract enemy_launcher zones here.
        _al = cls.ally_launcher
        if _al:
            _wide_al     = (_al | (_al << 1) | (_al >> 1)) & cls.board_mask
            _expanded_al = (_wide_al | (_wide_al << stride) | (_wide_al >> stride)) & cls.board_mask
            cls.enemy_now_passable_int = cls.passable_int & ~_expanded_al
        else:
            cls.enemy_now_passable_int = cls.passable_int

        ti_ore_adj = cls.ti_ore_adj

        for pos, x, y, idx, ti in Map.proc_nearby_tiles:
            if ti.has_bot:
                now_weight[idx] += 100

            if ti.env == Environment.ORE_TITANIUM:
                {% for off in (-1, 1, -PH, PH) %}
                ti_ore_adj[idx {{ sign0(off) }}] = True
                {% endfor %}
# ===---

    # incremental
                        
    {% set SENTINEL_WEIGHT = 3 %}
    @classmethod
    def add_enemy_sentinel(cls, pos, ti):
        for pos in Globals.ct.get_attackable_tiles_from(pos, ti.turret_direction, ti.entity_type):
            cls.weight[{{ encode_pos('pos.x', 'pos.y') }}] += {{ SENTINEL_WEIGHT }}

    @classmethod
    def remove_enemy_sentinel(cls, pos, turret_dir):
        for pos in Globals.ct.get_attackable_tiles_from(pos, turret_dir, EntityType.SENTINEL):
            i = {{ encode_pos('pos.x', 'pos.y') }}
            cls.weight[i] -= {{ SENTINEL_WEIGHT }}
            if cls.weight[i] < 1:
                cls.weight[i] = 1

    @classmethod
    def add_enemy_launcher(cls, idx):
        x = idx // {{ PH }} - {{ PAD }}
        y = idx %  {{ PH }} - {{ PAD }}
        bit = 1 << (x * cls.STRIDE + y)
        cls.enemy_launcher |= bit
        {% for dir in directions[:8] %}
        {% set dx, dy = dir.delta() %}
        {% set off = dx * PH + dy %}
        cls.weight[idx + {{ off }}] += {{ INF }}
        {% endfor %}

        {% if LOCAL %}
        Debug.dot(Position(x, y), Color.YELLOW)
        {% endif %}

    @classmethod
    def remove_enemy_launcher(cls, idx):
        x = idx // {{ PH }} - {{ PAD }}
        y = idx %  {{ PH }} - {{ PAD }}
        bit = 1 << (x * cls.STRIDE + y)
        cls.enemy_launcher &= ~bit
        {% for dir in directions[:8] %}
        {% set dx, dy = dir.delta() %}
        {% set off = dx * PH + dy %}
        i = idx + {{ off }}
        cls.weight[i] -= {{ INF }}
        if cls.weight[i] < 1:
            cls.weight[i] = 1
        {% endfor %}

        {% if LOCAL %}
        Debug.dot(Position(x, y), Color.GREEN)
        {% endif %}

    # [NEW] ── Ally launcher tracking (enemy-perspective danger zones) ──────────
    # Ally launchers block ENEMY bot movement in the same 3×3 pattern that
    # enemy launchers block OUR movement. These methods maintain ally_launcher
    # incrementally so enemy_now_passable_int can be derived cheaply each turn.
    # We do NOT touch cls.weight here — our own bots are unaffected by our
    # own launcher zones.

    @classmethod
    def add_ally_launcher(cls, idx: int):
        """
        Register a newly-seen ally LAUNCHER.
        Sets its bit in ally_launcher; the 3×3 danger zone will be carved
        from enemy_now_passable_int in update() each turn.
        """
        x = idx // {{ PH }} - {{ PAD }}
        y = idx %  {{ PH }} - {{ PAD }}
        cls.ally_launcher |= 1 << (x * cls.STRIDE + y)
        {% if LOCAL %}
        Debug.dot(Position(x, y), Color.CYAN)
        {% endif %}

    @classmethod
    def remove_ally_launcher(cls, idx: int):
        """
        Deregister an ally LAUNCHER that was destroyed or left vision scope.
        Clears its bit from ally_launcher.
        """
        x = idx // {{ PH }} - {{ PAD }}
        y = idx %  {{ PH }} - {{ PAD }}
        cls.ally_launcher &= ~(1 << (x * cls.STRIDE + y))
        {% if LOCAL %}
        Debug.dot(Position(x, y), Color.LIME)
        {% endif %}
    # [END NEW] ──────────────────────────────────────────────────────────────────


    {% for avoid_ti_adj in True, False %}
# ---===
    @classmethod
    def find_bridge_route{{ '_avoid_ti_adj' if avoid_ti_adj }}(
            cls, start: Position, sink_set: set[int], max_iter: int = 500, avoid_pos: set[int] = set(),
            use_ally_routing: bool = False
        ):
        {% set main_bridge_offsets = [
            (3,0),(-3,0),(0,3),(0,-3),
            (2,2),(2,-2),(-2,-2),(-2,2),
        ] %}

        {% set seed_bridge_offsets = [
            (3,0),(-3,0),(0,3),(0,-3),
            (2,2),(2,-2),(-2,-2),(-2,2),
            (1,2),(2,1),(2,-1),(1,-2),
            (-1,-2),(-2,-1),(-2,1),(-1,2),
        ] %}

        passable = cls.passable_bridge
        if use_ally_routing:
            _ar = cls.ally_routing
            _sf = DarkForest.sight_flowing
            _pr = DarkForest.pressure
            {% set FLOW_THR = 12 * 3 - 12 %}
            feeder = [_ar[_i] and _sf[_i] and _pr[_i] < {{ FLOW_THR }} for _i in range(len(_ar))]
        else:
            feeder = cls.harvester_feeder
        visited = [False] * {{ PADDED_GRID_SIZE }}
        first_hop = [None] * {{ PADDED_GRID_SIZE }}
        dist = [0] * {{ PADDED_GRID_SIZE }}

        {% if avoid_ti_adj %}
        ti_ore_adj = cls.ti_ore_adj
        {% endif %}

        enclosed_region = cls.enclosed_region

        {% macro can_visit(ni) -%}
        (
            not visited[{{ ni }}] and
            {{ ni }} not in avoid_pos and
            not enclosed_region[{{ ni }}] and
            ({{ ni }} in sink_set or (
                (passable[{{ ni }}] or feeder[{{ ni }}])
                {% if avoid_ti_adj %}
                and not ti_ore_adj[{{ ni }}]
                and {{ ni }} not in Unit.core_pos_set
                {% endif %}
            ))
        )
        {%- endmacro %}

        sx, sy = start.x, start.y
        si = {{ encode_pos('sx', 'sy') }}
        visited[si] = True

        q = deque()
        _qa = q.append

        {% set CONVEYOR_DEPTH = 4 %}

        conv_reached = []
        _cra = conv_reached.append

        conv_front = []
        _cfa = conv_front.append
        {% for dx, dy in [(1,0),(-1,0),(0,1),(0,-1)] %}
        ni = si + {{ dx * PH + dy }}
        if {{ can_visit('ni') }}:
            visited[ni] = True
            first_hop[ni] = (sx {{ sign0(dx) }}, sy {{ sign0(dy) }})
            _cfa(ni)
            _cra(ni)
        {% endfor %}

        {% for _ in range(CONVEYOR_DEPTH - 1) %}
        conv_next = []
        _cna = conv_next.append
        for cidx in conv_front:
            _fh = first_hop[cidx]
            {% for dx, dy in [(1,0),(-1,0),(0,1),(0,-1)] %}
            ni = cidx + {{ dx * PH + dy }}
            if {{ can_visit('ni') }}:
                visited[ni] = True
                first_hop[ni] = _fh
                _cna(ni)
                _cra(ni)
            {% endfor %}
        conv_front = conv_next
        {% endfor %}

        for cidx in conv_reached:
            if cidx in sink_set:
                return 1, first_hop[cidx]
            _qa(cidx)
            dist[cidx] = 1

        {% for dx, dy in seed_bridge_offsets %}
        ni = si + {{ dx * PH + dy }}
        if {{ can_visit('ni') }}:
            visited[ni] = True
            first_hop[ni] = (sx {{ sign0(dx) }}, sy {{ sign0(dy) }})
            if ni in sink_set:
                return 1, first_hop[ni]
            dist[ni] = 1
            _qa(ni)
        {% endfor %}

        it = 0
        while q and (it := it + 1) <= max_iter:
            idx = q.popleft()
            d = dist[idx] + 1
            fh = first_hop[idx]

            {% for dx, dy in main_bridge_offsets %}
            ni = idx + {{ dx * PH + dy }}
            if {{ can_visit('ni') }}:
                visited[ni] = True
                dist[ni] = d
                first_hop[ni] = fh
                if ni in sink_set:
                    return d, fh
                _qa(ni)
            {% endfor %}

        return {{ INF }}, None
# ===---
    {% endfor %}

    {% for variant_suffix, road_w, empty_w in [
        ('',     1, 2),
        ('_inv', 2, 1),
    ] %}
# ---===
    @classmethod
    def find_route{{ variant_suffix }}(cls, start: Position, target: Position,
                   ban_target: bool = False,
                   max_iter: int = 200) -> tuple[int, Direction | None]:
        {% set WEIGHTED_DEPTH = 5 %}

        sx, sy = start.x, start.y
        _tx, _ty = target.x, target.y

        weight = cls.now_weight
        stride = cls.STRIDE

        si = {{ encode_pos('sx', 'sy') }}
        ti = {{ encode_pos('_tx', '_ty') }}
        center_weight = weight[si] if weight[si] > 5 else 1

        _D = ({% for d in range(8) %}{{ directions[d] }}{% if not loop.last %}, {% endif %}{% endfor %})

        if si == ti:
            {% if LOCAL %}
            print(f'[on top of find_route{{ variant_suffix }} target with {ban_target=}]')
            {% endif %}
            
            if ban_target:
                _best_c = {{ INF }}
                _best_d = None
            else:
                _best_c = center_weight
                _best_d = Direction.CENTRE if center_weight < {{ INF }} else None
            {% for dir in range(8) %}
            ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            w = weight[ni]
            {% if road_w != 1 %}
            if w <= 2: w = 3 - w
            {% endif %}
            if w < _best_c and MoveManager.can_fill_move({{ directions[dir] }}):
                _best_c = w
                _best_d = {{ directions[dir] }}
            {% endfor %}
            if _best_d is not None:
                return _best_c, _best_d
            return {{ INF }}, None

        if ban_target:
            _d = si - ti
            _ad = _d if _d >= 0 else -_d
            if _ad == 1 or _ad == {{ PH - 1 }} or _ad == {{ PH }} or _ad == {{ PH + 1 }}:
                _best_c = center_weight
                _best_d = Direction.CENTRE if center_weight < {{ INF }} else None
                {% for dir in range(8) %}
                ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
                if ni != ti:
                    w = weight[ni]
                    {% if road_w != 1 %}
                    if w <= 2: w = 3 - w
                    {% endif %}
                    if w < _best_c and MoveManager.can_fill_move({{ directions[dir] }}):
                        _best_c = w
                        _best_d = {{ directions[dir] }}
                {% endfor %}
                if _best_d is not None:
                    return _best_c, _best_d
                return {{ INF }}, None

        pre_weight = weight[ti]
        # weight[ti] = 1 if weight[ti] < 10 else weight[ti]
        weight[ti] = 1

        {{ P.start('BfsBureau.find_route{{ variant_suffix }}') }}
        {% set before_ret -%}
        weight[ti] = pre_weight; {{ P.end('BfsBureau.find_route{{ variant_suffix }}') }}
        {%- endset %}

        dist = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
        fhd  = [0]       * {{ PADDED_GRID_SIZE }}
        dist[si] = 0

        heap  = []
        _hp   = heapq.heappush
        _hpop = heapq.heappop

        _settled = [si]
        _sa = _settled.append

        {% if road_w == 1 %}
        {% for dir in range(8) %}
        ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
        if weight[ni] < {{ INF }} and MoveManager.can_fill_move({{ directions[dir] }}):
            w = weight[ni]
            dist[ni] = w
            fhd[ni]  = {{ dir }}
            if ni == ti:
                {{ before_ret }}
                return w, {{ directions[dir] }}
            _hp(heap, (w, ni))
        {% endfor %}
        {% else %}
        {% for dir in range(8) if Dir.dx[dir] == 0 or Dir.dy[dir] == 0 %}
        ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
        if weight[ni] < {{ INF }} and MoveManager.can_fill_move({{ directions[dir] }}):
            w = weight[ni]
            if w <= 2: w = 3 - w
            dist[ni] = w
            fhd[ni]  = {{ dir }}
            if ni == ti:
                {{ before_ret }}
                return w, {{ directions[dir] }}
            _hp(heap, (w, ni))
        {% endfor %}
        {% for dir in range(8) if Dir.dx[dir] != 0 and Dir.dy[dir] != 0 %}
        ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
        if weight[ni] < {{ INF }} and MoveManager.can_fill_move({{ directions[dir] }}):
            w = weight[ni]
            if w <= 2: w = 3 - w
            if w < dist[ni]:
                dist[ni] = w
                fhd[ni]  = {{ dir }}
                if ni == ti:
                    {{ before_ret }}
                    return w, {{ directions[dir] }}
                _hp(heap, (w, ni))
            elif w == dist[ni]:
                fhd[ni] = {{ dir }}
        {% endfor %}
        {% endif %}

        phase2_seeds = []
        _p2a = phase2_seeds.append

        while heap:
            d, idx = _hpop(heap)
            if d > dist[idx]:
                continue

            _sa(idx)

            if d >= {{ WEIGHTED_DEPTH }}:
                _p2a(idx)
                while heap:
                    _dd, _idx = _hpop(heap)
                    if _dd == dist[_idx]:
                        _sa(_idx)
                        _p2a(_idx)
                break

            _fh = fhd[idx]
            {% for dir in range(8) %}
            ni = idx + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            w  = weight[ni]

            {% if LOCAL %}
            assert w >= 0, 'negative edge weight in dijkstra'
            {% endif %}

            if w < {{ INF }}:
                {% if road_w != 1 %}
                if w <= 2: w = 3 - w
                {% endif %}
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        {{ before_ret }}
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            {% endfor %}

        if not phase2_seeds:
            {{ before_ret }}
            return {{ INF }}, None


        _tb = _tx * stride + _ty
        _tm = 1 << _tb
        _uc = (cls.now_passable_int | _tm) & cls.board_mask

        _settled_bits = 0
        for _ci in _settled:
            _cx = _ci // {{ PH }} - {{ PAD }}
            _cy = _ci % {{ PH }} - {{ PAD }}
            _settled_bits |= 1 << (_cx * stride + _cy)
        _uc &= ~_settled_bits

        {% for dir in range(8) %}
        _fh{{ dir }} = 0
        _md{{ dir }} = {{ INF }}
        {% endfor %}

        for _ci in phase2_seeds:
            _cx = _ci // {{ PH }} - {{ PAD }}
            _cy = _ci % {{ PH }} - {{ PAD }}
            _di = fhd[_ci]
            _bit = 1 << (_cx * stride + _cy)
            {% for dir in range(8) %}
            {{ 'if' if loop.first else 'elif' }} _di == {{ dir }}:
                _fh{{ dir }} |= _bit
                if dist[_ci] < _md{{ dir }}:
                    _md{{ dir }} = dist[_ci]
            {% endfor %}

        _bfs_d = 0
        it = 0
        while (it := it + 1) <= max_iter:
            _any = False

            {% for dir in range(8) %}
            _f = _fh{{ dir }}
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << stride) | (_v >> stride)) & _uc
                _e &= ~_f
                if _e:
                    _fh{{ dir }} = _e
                    _uc &= ~_e
                    _any = True
                    if _e & _tm:
                        {{ before_ret }}
                        return _md{{ dir }} + _bfs_d + 1, _D[{{ dir }}]
                else:
                    _fh{{ dir }} = 0
            {% endfor %}

            if not _any:
                break
            _bfs_d += 1

        {{ before_ret }}
        return {{ INF }}, None
# ===---
    {% endfor %}

    # ── bfs20 ────────────────────────────────────────────────────────────────────
    bfs20_dist: list[int] = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
    bfs20_dist_adj: list[int] = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
    _bfs20_touched_indices: list[int] = []
    _bfs20_dist_adj_touched: list[int] = []
    _BFS20_VALID_OFFSETS = frozenset({
        {% for dx in range(-4, 5) %}
        {% for dy in range(-4, 5) %}
        {% if dx*dx + dy*dy <= 20 %}
        {{ dx * PH + dy }},
        {% endif %}
        {% endfor %}
        {% endfor %}
    })

    # [NEW] ── enemy_bot_bfs storage ─────────────────────────────────────────────
    # enemy_bot_dist[padded_idx] = unweighted BFS distance to nearest visible
    # enemy bot, modelled from the ENEMY'S movement perspective:
    #   - blocked by walls + impassable buildings  (passable_int, same for all)
    #   - blocked by ALLY launcher 3×3 zones       (our launchers threaten them)
    #   - NOT blocked by ENEMY launcher 3×3 zones  (those are their own launchers)
    enemy_bot_dist: list[int] = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
    _enemy_bot_dist_touched: list[int] = []

    # [NEW-ADJ] ── enemy_bot_dist_adj storage ────────────────────────────────────
    # Mirrors the relationship between bfs20_dist and bfs20_dist_adj:
    #   enemy_bot_dist_adj[idx] = min(enemy_bot_dist[idx],
    #                                 min over 8 neighbours of enemy_bot_dist[neighbour])
    # In other words: the distance that the *closest reachable enemy bot* would
    # need to reach any tile ADJACENT TO (or equal to) idx.
    # This is useful for evaluating how threatened a tile is — even if the enemy
    # cannot step onto idx itself, it might be able to attack from a neighbour.
    enemy_bot_dist_adj: list[int] = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
    _enemy_bot_dist_adj_touched: list[int] = []
    # [END NEW-ADJ] ──────────────────────────────────────────────────────────────
    # [END NEW] ──────────────────────────────────────────────────────────────────

# ---===
    @classmethod
    def bfs20(cls):
        """Weighted Dijkstra from pos, limited to tiles within vision r²≤20."""
        weight = cls.now_weight
        distances = cls.bfs20_dist
        distances_adj = cls.bfs20_dist_adj
        IMPASSABLE = {{ INF }}

        for touched_index in cls._bfs20_touched_indices:
            distances[touched_index] = IMPASSABLE
        for touched_index in cls._bfs20_dist_adj_touched:
            distances_adj[touched_index] = IMPASSABLE

        pos = Globals.my_pos
        start_x, start_y = pos.x, pos.y
        start_index = {{ encode_pos('start_x', 'start_y') }}

        distances[start_index] = 0
        touched_indices = [start_index]
        valid_offsets = cls._BFS20_VALID_OFFSETS

        priority_queue = []
        push_to_queue = heapq.heappush
        pop_from_queue = heapq.heappop

        {% for dir in range(8) %}
        neighbor_index = start_index + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
        tile_weight = weight[neighbor_index]
        if tile_weight < IMPASSABLE:
            distances[neighbor_index] = tile_weight
            touched_indices.append(neighbor_index)
            push_to_queue(priority_queue, (tile_weight, neighbor_index))
        {% endfor %}

        while priority_queue:
            current_dist, current_index = pop_from_queue(priority_queue)
            if current_dist > distances[current_index]:
                continue
            {% for dir in range(8) %}
            neighbor_index = current_index + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            if (neighbor_index - start_index) in valid_offsets:
                tile_weight = weight[neighbor_index]
                if tile_weight < IMPASSABLE:
                    new_dist = current_dist + tile_weight
                    if new_dist < distances[neighbor_index]:
                        distances[neighbor_index] = new_dist
                        touched_indices.append(neighbor_index)
                        push_to_queue(priority_queue, (new_dist, neighbor_index))
            {% endfor %}

        cls._bfs20_touched_indices = touched_indices

        dist_adj_touched_set = set()
        for idx in touched_indices:
            d = distances[idx]
            if d >= IMPASSABLE:
                continue
            if d < distances_adj[idx]:
                distances_adj[idx] = d
                dist_adj_touched_set.add(idx)
            {% for dir in range(8) %}
            ni = idx + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            if (ni - start_index) in valid_offsets and d < distances_adj[ni]:
                distances_adj[ni] = d
                dist_adj_touched_set.add(ni)
            {% endfor %}

        cls._bfs20_dist_adj_touched = list(dist_adj_touched_set)

        # [NEW] run enemy-perspective BFS each turn immediately after bfs20
        # so enemy_bot_dist is always fresh when the rest of the bot reads it.
        cls.enemy_bot_bfs()
        # [END NEW]
# ===---

# ---===
    @classmethod
    def get_bfs20_dist(cls, pos: Position):
        return cls.bfs20_dist[{{ encode_pos('pos.x', 'pos.y') }}]
# ===---

    # [NEW] ── Enemy-bot-perspective BFS ─────────────────────────────────────────
    #
    # PURPOSE
    # -------
    # Answers "how many steps would an enemy bot need to reach tile T?"
    # under the enemy's movement rules:
    #
    #   Blocked by:
    #     • Walls and impassable ally/enemy buildings  → passable_int (shared truth)
    #     • 3×3 zones around OUR (ally) launchers      → ally_launcher bitmask
    #       (enemy bots avoid our launchers just as we avoid theirs)
    #
    #   NOT blocked by:
    #     • 3×3 zones around ENEMY launchers           → those are THEIR ally launchers;
    #       they walk freely underneath them.
    #     • Sentinel/gunner weight penalties in now_weight — those are for our routing.
    #
    # BITMASK LAYOUT
    # --------------
    # Mirrors now_passable_int exactly.
    # Bit position b = x * STRIDE + y  ↔  map cell (x, y).
    # board_mask clips everything to [0, W) × [0, H).
    #
    # 8-DIRECTIONAL EXPANSION (one BFS step)
    # ----------------------------------------
    #   horiz  = (f << STRIDE) | (f >> STRIDE)   — neighbours at x±1
    #   vert   = (f << 1)      | (f >> 1)         — neighbours at y±1
    #   diag   = (horiz << 1)  | (horiz >> 1)     — diagonal neighbours (x±1, y±1)
    #   expand = (horiz | vert | diag) & unvisited & board_mask
    #
    # RESET STRATEGY
    # --------------
    # Only indices written last turn are reset (O(reached) not O(grid)).
    #
    # [END NEW comment block]

# ---===
    @classmethod
    def enemy_bot_bfs(cls):
        IMPASSABLE = {{ INF }}
        distances  = cls.enemy_bot_dist
        stride     = cls.STRIDE
        board_mask = cls.board_mask

        # ── 1. Reset last turn's written distances ─────────────────────────────
        for idx in cls._enemy_bot_dist_touched:
            distances[idx] = IMPASSABLE

        # [NEW-ADJ] Reset last turn's written adj distances ─────────────────────
        distances_adj = cls.enemy_bot_dist_adj
        for idx in cls._enemy_bot_dist_adj_touched:
            distances_adj[idx] = IMPASSABLE
        # [END NEW-ADJ] ─────────────────────────────────────────────────────────

        enemy_passable = cls.enemy_now_passable_int

        # ── 2. Build vision mask: only tiles within r²≤20 of our position ──────
        pos = Globals.my_pos
        px, py = pos.x, pos.y
        vision_mask: int = 0
        {% for dx in range(-4, 5) %}
        {% for dy in range(-4, 5) %}
        {% if dx*dx + dy*dy <= 20 %}
        _vx = px + {{ dx }}; _vy = py + {{ dy }}
        if 0 <= _vx < Map.W and 0 <= _vy < Map.H:
            vision_mask |= 1 << (_vx * stride + _vy)
        {% endif %}
        {% endfor %}
        {% endfor %}

        # ── 3. Collect seed positions from visible enemy bots ──────────────────
        seed_bits: int = 0
        seed_pairs: list[tuple[int, int]] = []

        for _pos, x, y, idx, ti in Map.proc_nearby_tiles:
            if ti.has_bot and not ti.is_bot_ally:
                b          = x * stride + y
                seed_bits |= 1 << b
                seed_pairs.append((idx, b))

        if not seed_bits:
            cls._enemy_bot_dist_touched = []
            # [NEW-ADJ] also clear adj touched list when no enemy bots visible
            cls._enemy_bot_dist_adj_touched = []
            # [END NEW-ADJ]
            return

        # ── 4. Initialise BFS — cap unvisited to vision_mask ──────────────────
        unvisited: int = (enemy_passable | seed_bits) & board_mask & vision_mask
        frontier:  int = seed_bits & board_mask
        unvisited       &= ~frontier

        touched_pairs = list(seed_pairs)
        for idx, _ in seed_pairs:
            distances[idx] = 0

        dist = 0

        # ── 5. BFS expansion (naturally stays in-vision via unvisited mask) ────
        while frontier:
            dist += 1

            horiz    = ((frontier << stride) | (frontier >> stride)) & board_mask
            vert     = ((frontier << 1)      | (frontier >> 1))      & board_mask
            diag     = ((horiz    << 1)      | (horiz    >> 1))      & board_mask
            expanded = (horiz | vert | diag) & unvisited

            if not expanded:
                break

            unvisited &= ~expanded
            frontier   =  expanded

            bits = expanded
            while bits:
                lsb   =  bits & -bits
                bits  ^= lsb
                b     =  lsb.bit_length() - 1
                bx    =  b // stride
                by    =  b %  stride
                pidx  = {{ encode_pos('bx', 'by') }}
                distances[pidx] = dist
                touched_pairs.append((pidx, b))

        cls._enemy_bot_dist_touched = [i for i, _ in touched_pairs]

        # [NEW-ADJ] ── Build enemy_bot_dist_adj from enemy_bot_dist ──────────────
        # Exactly mirrors the bfs20_dist_adj logic in bfs20():
        #   for every tile idx that has a finite enemy_bot_dist d:
        #     • propagate d into distances_adj[idx]          (self)
        #     • propagate d into distances_adj[neighbour]    (all 8 neighbours)
        #       if neighbour is within vision r²≤20
        # This means distances_adj[idx] = min enemy_bot_dist over {idx} ∪ neighbours(idx).
        #
        # We reuse _enemy_bot_dist_touched (all written padded indices) as the
        # iteration source — the same set bfs20_dist_adj uses (_bfs20_touched_indices).
        # We need the start_index for the valid_offsets check.
        valid_offsets = cls._BFS20_VALID_OFFSETS
        start_x = px
        start_y = py
        start_index = {{ encode_pos('start_x', 'start_y') }}

        dist_adj_touched_set: set[int] = set()

        for idx in cls._enemy_bot_dist_touched:
            d = distances[idx]
            if d >= IMPASSABLE:
                continue
            # propagate to self
            if d < distances_adj[idx]:
                distances_adj[idx] = d
                dist_adj_touched_set.add(idx)
            # propagate to all 8 neighbours that are within vision
            {% for dir in range(8) %}
            ni = idx + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            if (ni - start_index) in valid_offsets and d < distances_adj[ni]:
                distances_adj[ni] = d
                dist_adj_touched_set.add(ni)
            {% endfor %}

        cls._enemy_bot_dist_adj_touched = list(dist_adj_touched_set)
        # [END NEW-ADJ] ──────────────────────────────────────────────────────────
# ===---

    # [NEW] ── Convenience accessor ───────────────────────────────────────────────
# ---===
    @classmethod
    def get_enemy_bot_dist(cls, pos: Position) -> int:
        """[NEW] Return the precomputed enemy-bot BFS distance to pos (INF if unreachable)."""
        return cls.enemy_bot_dist[{{ encode_pos('pos.x', 'pos.y') }}]
# ===---
    # [END NEW] ──────────────────────────────────────────────────────────────────

    # [NEW-ADJ] ── Convenience accessor for enemy_bot_dist_adj ──────────────────
# ---===
    @classmethod
    def get_enemy_bot_dist_adj(cls, pos: Position) -> int:
        """
        [NEW-ADJ] Return the precomputed enemy_bot_dist_adj value for pos.

        This equals min(enemy_bot_dist[pos], min over 8 neighbours of enemy_bot_dist[neighbour]),
        i.e. the fewest steps an enemy bot would need to reach any tile that is
        pos itself OR directly adjacent to pos (within the in-vision BFS frontier).

        Useful for asking: "could an enemy bot attack this tile next turn?"
        Returns INF if no enemy bot can reach pos or any of its neighbours.
        """
        return cls.enemy_bot_dist_adj[{{ encode_pos('pos.x', 'pos.y') }}]
# ===---
    # [END NEW-ADJ] ──────────────────────────────────────────────────────────────

# ---===
    @classmethod
    def debug_bfs20(cls):
        distances = cls.bfs20_dist
        IMPASSABLE = {{ INF }}

        pos = Globals.my_pos
        start_x, start_y = pos.x, pos.y
        start_index = {{ encode_pos('start_x', 'start_y') }}

        {% for dx in range(-4, 5) %}
        {% for dy in range(-4, 5) %}
        {% if dx*dx + dy*dy <= 20 %}
        tile_x = start_x + {{ dx }}
        tile_y = start_y + {{ dy }}
        if 0 <= tile_x < Map.W and 0 <= tile_y < Map.H:
            tile_index = start_index + {{ dx * PH + dy }}
            if distances[tile_index] < IMPASSABLE:
                Debug.dot(Position(tile_x, tile_y), Color.WHITE)
            else:
                Debug.dot(Position(tile_x, tile_y), Color.BLACK)
        {% endif %}
        {% endfor %}
        {% endfor %}
# ===---
