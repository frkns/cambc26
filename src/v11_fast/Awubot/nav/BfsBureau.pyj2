            {# /* if ni in sink_set: */ #}
                {# /* return 1, first_hop_pos[{{ dir_idx }}] */ #}
            {# /* nx = ni // {{ PH }} - {{ PAD }} */ #}
            {# /* ny = ni % {{ PH }} - {{ PAD }} */ #}
            {# /* bit = 1 << (nx * _BS + ny) */ #}
            {# /* visited_bitmask |= bit */ #}
            {# /* frontier_{{ dir_idx }} |= bit */ #}
            {# /* node_count += 1 */ #}
        {# /* {% endfor %} */ #}

        {# /* if node_count == 0: */ #}
            {# /* return {{ INF }}, None */ #}

        {# /* # ── Phase 3: bitmask BFS using bridge jumps ── */ #}
        {# /* # Unvisited and passable (sinks are also valid destinations) */ #}
        {# /* unvisited_passable = (cls.bridge_passable_int | sink_bitmask) & ~visited_bitmask */ #}

        {# /* # Pre-compute bridge offset shifts */ #}
        {# /* _3BS = 3 * _BS */ #}
        {# /* _2BS2 = 2 * _BS + 2 */ #}
        {# /* _2BSm2 = 2 * _BS - 2 */ #}

        {# /* bfs_depth = 1 */ #}
        {# /* while node_count < {{ BFS_NODE_LIMIT }}: */ #}
            {# /* any_expanded = False */ #}

            {# /* {% for dir in range(8) %} */ #}
            {# /* _f = frontier_{{ dir }} */ #}
            {# /* if _f: */ #}
                {# /* # Bridge reachable: all 8 offsets within r²≤9 */ #}
                {# /* expanded = ( */ #}
                    {# /* (_f << _3BS) | (_f >> _3BS) | */ #}
                    {# /* (_f << 3) | (_f >> 3) | */ #}
                    {# /* (_f << _2BS2) | (_f >> _2BS2) | */ #}
                    {# /* (_f << _2BSm2) | (_f >> _2BSm2) */ #}
                {# /* ) & unvisited_passable */ #}
                {# /* if expanded: */ #}
                    {# /* frontier_{{ dir }} = expanded */ #}
                    {# /* unvisited_passable ^= expanded */ #}
                    {# /* node_count += expanded.bit_count() */ #}
                    {# /* any_expanded = True */ #}
                    {# /* if expanded & sink_bitmask: */ #}
                        {# /* return bfs_depth + 1, first_hop_pos[{{ dir }}] */ #}
                {# /* else: */ #}
                    {# /* frontier_{{ dir }} = 0 */ #}
            {# /* {% endfor %} */ #}

            {# /* if not any_expanded: */ #}
                {# /* break */ #}
            {# /* bfs_depth += 1 */ #}

        {# /* return {{ INF }}, None */ #}
{# /* # ===--- */ #}

    # works. but slow
# ---===
    @classmethod
    def find_bridge_route(cls, start: Position, sink_set: set[int], max_iter: int = 1000):
        {% set main_bridge_offsets = [
            (3,0),(-3,0),(0,3),(0,-3),
            (2,2),(2,-2),(-2,-2),(-2,2),
        ] %}

        {% set seed_bridge_offsets = [
            (3,0),(-3,0),(0,3),(0,-3),
            (2,2),(2,-2),(-2,-2),(-2,2),
            (1,2),(2,1),(2,-1),(1,-2),
            (-1,-2),(-2,-1),(-2,1),(-1,2),
        ] %}

        dist = cls.dist_bridge[:]
        first_hop = [None] * {{ PADDED_GRID_SIZE }}

        sx, sy = start.x, start.y
        si = {{ encode_pos('sx', 'sy') }}
        dist[si] = 0

        # sink nodes are destinations, not transit — make them visible to BFS
        # we return immediately on first hit, so they're never traversed through
        for s in sink_set:
            if dist[s] == {{ INF1 }}:  # redundant check?
                dist[s] = {{ INF }}

        q = deque()
        _qa = q.append

        {% set CONVEYOR_DEPTH = 4 %}

        # ── Phase 1: conveyor mini-BFS (≤4 cardinal steps from start) ──
        conv_reached = []
        _cra = conv_reached.append

        # First cardinal step: first_hop = that adjacent tile
        conv_front = []
        _cfa = conv_front.append
        {% for dx, dy in [(1,0),(-1,0),(0,1),(0,-1)] %}
        ni = si + {{ dx * PH + dy }}
        if dist[ni] == {{ INF }}:
            dist[ni] = -1
            first_hop[ni] = (sx {{ sign0(dx) }}, sy {{ sign0(dy) }})
            _cfa(ni)
            _cra(ni)
        {% endfor %}

        # Steps 2–4: propagate first_hop from parent
        {% for _ in range(CONVEYOR_DEPTH - 1) %}
        conv_next = []
        _cna = conv_next.append
        for cidx in conv_front:
            _fh = first_hop[cidx]
            {% for dx, dy in [(1,0),(-1,0),(0,1),(0,-1)] %}
            ni = cidx + {{ dx * PH + dy }}
            if dist[ni] == {{ INF }}:
                dist[ni] = -1
                first_hop[ni] = _fh
                _cna(ni)
                _cra(ni)
            {% endfor %}
        conv_front = conv_next
        {% endfor %}

        # ── Phase 2: seed conveyors first (priority over bridges) ──

        for cidx in conv_reached:
            if dist[cidx] == -1:
                dist[cidx] = 1
                if cidx in sink_set:
                    return 1, first_hop[cidx]
                _qa(cidx)

        # ── Phase 3: bridge seeds for tiles conveyors couldn't reach ──
        {% for dx, dy in seed_bridge_offsets %}
        ni = si + {{ dx * PH + dy }}
        if dist[ni] == {{ INF }}:
            dist[ni] = 1
            first_hop[ni] = (sx {{ sign0(dx) }}, sy {{ sign0(dy) }})
            if ni in sink_set:
                return 1, first_hop[ni]
            _qa(ni)
        {% endfor %}

        # ── Phase 4: main bridge BFS ──

        it = 0
        while q and (it := it + 1) <= max_iter:
            idx = q.popleft()
            d = dist[idx] + 1
            fh = first_hop[idx]

            {% for dx, dy in main_bridge_offsets %}
            ni = idx + {{ dx * PH + dy }}
            if dist[ni] == {{ INF }}:
                dist[ni] = d
                first_hop[ni] = fh
                if ni in sink_set:
                    return d, fh
                _qa(ni)
            {% endfor %}

        return {{ INF }}, None
# ===---

    # outward depth-limited dijkstra + bitmask bfs
    # ---===
    @classmethod
    def find_route(cls, start: Position, target: Position,
                   ban_target: bool = False) -> tuple[int, Direction | None]:
        {% set WEIGHTED_DEPTH = 8 %}

        sx, sy = start.x, start.y
        _tx, _ty = target.x, target.y

        _w = cls.weight
        _S = cls.STRIDE

        si = {{ encode_pos('sx', 'sy') }}
        ti = {{ encode_pos('_tx', '_ty') }}

        _D = ({% for d in range(8) %}{{ directions[d] }}{% if not loop.last %}, {% endif %}{% endfor %})

        # ── Same-tile shortcuts ──
        if si == ti:
            if not ban_target:
                return 0, Direction.CENTRE
            {% for dir in range(8) %}
            ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            if _w[ni] < {{ INF }} and MoveManager.can_fill_move({{ directions[dir] }}):
                return 1, {{ directions[dir] }}
            {% endfor %}
            return {{ INF }}, None

        if ban_target:
            _d = si - ti
            _ad = _d if _d >= 0 else -_d
            if _ad == 1 or _ad == {{ PH - 1 }} or _ad == {{ PH }} or _ad == {{ PH + 1 }}:
                return 0, Direction.CENTRE

        _save = _w[ti]
        _w[ti] = 1

        # we do this because try...finally is banned by engine
        {% set before_ret -%}
            _w[ti] = _save; {{ P.end('BfsBureau.find_route[bfs]') }}
        {%- endset %}

        # ── Phase 1: weighted Dijkstra up to {{ WEIGHTED_DEPTH }} ──
        dist = [{{ INF }}] * {{ PADDED_GRID_SIZE }}
        fhd  = [0]       * {{ PADDED_GRID_SIZE }}
        dist[si] = 0

        heap  = []
        _hp   = heapq.heappush
        _hpop = heapq.heappop

        _settled = [si]
        _sa = _settled.append

        {% for dir in range(8) %}
        ni = si + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
        if _w[ni] < {{ INF }} and MoveManager.can_fill_move({{ directions[dir] }}):
            w = _w[ni]
            dist[ni] = w
            fhd[ni]  = {{ dir }}
            if ni == ti:
                {{ before_ret }}
                return w, {{ directions[dir] }}
            _hp(heap, (w, ni))
        {% endfor %}

        phase2_seeds = []
        _p2a = phase2_seeds.append

        while heap:
            d, idx = _hpop(heap)
            if d > dist[idx]:
                continue

            _sa(idx)

            if d >= {{ WEIGHTED_DEPTH }}:
                _p2a(idx)
                while heap:
                    _dd, _idx = _hpop(heap)
                    if _dd == dist[_idx]:
                        _sa(_idx)
                        _p2a(_idx)
                break

            _fh = fhd[idx]
            {% for dir in range(8) %}
            ni = idx + {{ Dir.dx[dir] * PH + Dir.dy[dir] }}
            w  = _w[ni]
            if w < {{ INF }}:
                nd = d + w
                if nd < dist[ni]:
                    dist[ni] = nd
                    fhd[ni]  = _fh
                    if ni == ti:
                        {{ before_ret }}
                        return nd, _D[_fh]
                    _hp(heap, (nd, ni))
            {% endfor %}

        if not phase2_seeds:
            {{ before_ret }}
            return {{ INF }}, None

        # ── Phase 2: bitmask BFS from Dijkstra frontier ──
        {{ P.start() }}
        _tb = _tx * _S + _ty
        _tm = 1 << _tb
        _uc = cls.passable_int | _tm

        _settled_bits = 0
        for _ci in _settled:
            _cx = _ci // {{ PH }} - {{ PAD }}
            _cy = _ci % {{ PH }} - {{ PAD }}
            _settled_bits |= 1 << (_cx * _S + _cy)
        _uc &= ~_settled_bits

        {% for dir in range(8) %}
        _fh{{ dir }} = 0
        _md{{ dir }} = {{ INF }}
        {% endfor %}

        for _ci in phase2_seeds:
            _cx = _ci // {{ PH }} - {{ PAD }}
            _cy = _ci % {{ PH }} - {{ PAD }}
            _di = fhd[_ci]
            _bit = 1 << (_cx * _S + _cy)
            {% for dir in range(8) %}
            {{ 'if' if loop.first else 'elif' }} _di == {{ dir }}:
                _fh{{ dir }} |= _bit
                if dist[_ci] < _md{{ dir }}:
                    _md{{ dir }} = dist[_ci]
            {% endfor %}

        _bfs_d = 0
        while True:
            _any = False

            {% for dir in range(8) %}
            _f = _fh{{ dir }}
            if _f:
                _v = _f | (_f << 1) | (_f >> 1)
                _e = (_v | (_v << _S) | (_v >> _S)) & _uc
                if _e:
                    _fh{{ dir }} = _e
                    _uc ^= _e
                    _any = True
                    if _e & _tm:
                        {{ before_ret }}
                        return _md{{ dir }} + _bfs_d + 1, _D[{{ dir }}]
                else:
                    _fh{{ dir }} = 0
            {% endfor %}

            if not _any:
                break
            _bfs_d += 1

        {{ before_ret }}
        return {{ INF }}, None
    # ===---
