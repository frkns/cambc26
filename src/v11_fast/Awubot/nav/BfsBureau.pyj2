                    {# /* frontier_{{ dir }} |= bit */ #}
                {# /* {% endfor %} */ #}

        {# /* # ── Phase 2: bridge seeds from start (tiles conveyors couldn't reach) ── */ #}
        {# /* {% for dx, dy in seed_bridge_offsets %} */ #}
        {# /* {% set sdx = 1 if dx > 0 else (-1 if dx < 0 else 0) %} */ #}
        {# /* {% set sdy = 1 if dy > 0 else (-1 if dy < 0 else 0) %} */ #}
        {# /* {% set dir_idx = _dlut[(sdx + 1) * 3 + (sdy + 1)] %} */ #}
        {# /* ni = si + {{ dx * PH + dy }} */ #}
